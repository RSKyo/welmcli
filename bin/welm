#!/usr/bin/env bash
# shellcheck disable=SC2034,SC1091
set -euo pipefail

# 禁用 history expansion（避免 ! 被 bash 解释）
set +o histexpand

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
PROJECT_DIR="$(cd -- "$SCRIPT_DIR/.." &>/dev/null && pwd)"

LIB_DIR="$PROJECT_DIR/lib"
NODE_DIR="$PROJECT_DIR/node"

source "$LIB_DIR/infra/log.source.sh"
source "$LIB_DIR/infra/runtime.source.sh"
source "$LIB_DIR/infra/deps.source.sh"
source "$LIB_DIR/infra/config.source.sh"

source "$LIB_DIR/browser/chrome.source.sh"

source "$LIB_DIR/node/cdp.source.sh"
source "$LIB_DIR/chatgpt.source.sh"

platform_detect || return 1
chrome_bin_resolve || return 1
chrome_bin_check || return 1

config_ensure || return 1
config_load

deps_require jq

clichatgpt_usage() {
  cat <<'EOF'
Usage:
  welmcli cdp  [args...]
  welmcli chatgpt [args...]

Commands:
  chatgpt    Talk to ChatGPT
  cdp        Run CDP helper commands
EOF
}

main() {
  local cmd="${1:--h}"

  case "$cmd" in
    cdp)
      shift || true
      cdp "$@"
      ;;
    chatgpt)
      shift || true
      chatgpt_talk "$@"
      ;;
    -h|--help|help)
      clichatgpt_usage
      ;;
    *)
      loge "unknown command: $cmd"
      clichatgpt_usage
      return 2
      ;;
  esac
}

main "$@"


# open -na "Google Chrome" "https://chatgpt.com/?temporary-chat=true" --args \
# --remote-debugging-port=9222 \
# --user-data-dir="$HOME/.local/share/clichatgpt/chrome-cdp-profile"

# 验证是否成功启动 CDP
# curl http://127.0.0.1:9222/json/version