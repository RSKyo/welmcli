#!/usr/bin/env bash
set -euo pipefail

# 禁用 history expansion（避免 ! 被 bash 解释）
set +o histexpand

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)"
PROJECT_DIR="$(cd -- "$SCRIPT_DIR/.." &>/dev/null && pwd)"
INFRA_DIR="$PROJECT_DIR/lib/infra"
LIB_DIR="$PROJECT_DIR/lib"

source "$INFRA_DIR/log.source.sh"
source "$INFRA_DIR/deps.source.sh"
source "$INFRA_DIR/config.source.sh"

source "$LIB_DIR/node/cdp.source.sh"
source "$LIB_DIR/macos_gui.source.sh"
source "$LIB_DIR/clichatgpt.source.sh"

welmcli_config_ensure
welmcli_config_load

require_cmds jq cliclick pbcopy pbpaste

clichatgpt_usage() {
  cat <<'EOF'
Usage:
  clichatgpt talk [args...]
  clichatgpt cdp  [args...]

Commands:
  talk    Talk to ChatGPT
  cdp     Run CDP helper commands
EOF
}

main() {
  local cmd="${1:-talk}"

  case "$cmd" in
    talk)
      shift || true
      clichatgpt_talk "$@"
      ;;
    cdp)
      shift || true
      cdp "$@"
      ;;
    -h|--help|help)
      clichatgpt_usage
      ;;
    *)
      loge "unknown command: $cmd"
      clichatgpt_usage
      return 2
      ;;
  esac
}

main "$@"


# open -na "Google Chrome" "https://chatgpt.com/?temporary-chat=true" --args \
# --remote-debugging-port=9222 \
# --user-data-dir="$HOME/.local/share/clichatgpt/chrome-cdp-profile"

# 验证是否成功启动 CDP
# curl http://127.0.0.1:9222/json/version